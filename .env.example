# 複製此檔案為 .env，並填入實際值
# Copy this file to .env and fill in the actual values

# Anthropic API（Agent mode 需要）
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Ragic ERP 連線設定
RAGIC_BASE=https://ap12.ragic.com
RAGIC_ACCOUNT=your_ragic_account_name

# Ragic 表單路徑（通常不需要改）
PRODUCT_PRICE_SHEET=ragicsales-order-management/20006
CUSTOMER_SHEET=ragicsales-order-management/20004
SALES_ORDER_SHEET=ragicsales-order-management/20001
ORDER_ITEMS_SUBTABLE_KEY=_subtable_3000842
DELIVERY_ORDER_SHEET=ragicsales-order-management/20002
OUTBOUND_ORDER_SHEET=ragicinventory/20009
INVENTORY_SHEET=ragicinventory/20008
